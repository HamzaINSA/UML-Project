@startuml
skinparam style strictuml
skinparam classAttributeIconSize 0

package "Model" {
    abstract class Utilisateur {
        - id : String
        - mdp : String
        - nom : String
        - email : String
    }

    class Agence extends Utilisateur {
        - serviceReference : String
        - zoneResponsabilite : String
    }

    class Particulier extends Utilisateur {
        - points : int
        - estFiable : bool
        - adresse : String
    }

    class Fournisseur extends Utilisateur {
        - nomEntreprise : String
        - numeroSiret : String
        - contactSupport : String
    }

    class Capteur {
        - id : String
        - latitude : double
        - longitude : double
        - estFiable : bool
    }

    class Mesure {
        - timestamp : DateTime
        - valeur : double
        - estValide : bool
    }

    class AttributMesure {
        - id : String
        - unite : String
        - description : String
    }

    class Purificateur {
        - id : String
        - latitude : double
        - longitude : double
        - dateDebut : DateTime
        - dateFin : DateTime
    }
}

package "Repository (Persistence)" {
    class DataReader {
        + getCapteur(idCapteur : String) : Capteur
        + getTousCapteurs() : List<Capteur>
        + getAutresCapteurs(idRef : String) : List<Capteur>
        + getCapteursDansRayon(lat : double, lon : double, rayon : double) : List<Capteur>
        + getCapteursVoisins(idCapteur : String) : List<Capteur>
        + getCapteursOfficielsVoisins(capteur : Capteur, rayon : double) : List<Capteur>
        + getMesuresCapteur(idCapteur : String, periode : Intervalle) : List<Mesure>
        + getMesuresPeriode(idCapteur : String, debut : DateTime, fin : DateTime) : List<Mesure>
        + getMesuresAuTimestamp(idCapteur : String, timestamp : DateTime) : List<Mesure>
        + getMesuresCapteursVoisins(idCapteur : String, periode : Intervalle) : List<Mesure>
        + getPurificateur(idPurificateur : String) : Purificateur
        + marquerCapteur(idCapteur : String, estFiable : bool)
        + marquerMesuresInvalides(idCapteur : String)
        + sauvegarderCapteur(capteur : Capteur)
    }
}

package "Service (Métiers)" {
    class AirQualityService {
        + calculerMoyenneZone(lat : double, lon : double, rayon : double, debut : DateTime, fin : DateTime) : double
        + estimerQualitePosition(lat : double, lon : double, timestamp : DateTime) : double
        + comparerCapteurs(idRef : String, debut : int , fin : int) : List<Capteur>
        - calculerIndiceATMOMoyen(mesures : List<Mesure>) : double
        - calculerIndiceATMO(mesures : List<Mesure>) : double
        - calculerScoreSimilarite(mesuresRef : List<Mesure>, mesures : List<Mesure>) : double
        - trierParScoreCroissant(classement : List)
        - selectionnerNCapteursProches(lat : double, lon : double, n : int) : List<Capteur>
        - interpolerPondereeParDistance(capteurs : List<Capteur>, lat : double, lon : double) : double
    }

    class AdministrationService {
        + analyserCapteur(idCapteur : String, periode : Intervalle) : Rapport
        + classifierFiabilite(idCapteur : String) : bool
        + attribuerPoints(particuliersImpliques : List<Particulier>)
        + desactiverAttributionPoints(idParticulier : String)
    }

    class EnvironmentalService {
        + mesurerImpact(idPurificateur : String) : ImpactPurificateur
        - calculerDelta(indiceAvant : double, indicePendant : double) : double
        - estimerRayonAction(purif : Purificateur) : double
    }

    class PerformanceMonitor {
        + demarrer(nomMethode : String)
        + arreter(nomMethode : String) : long
    }
}

package "View" {
    class ConsoleUI {
        + afficherMenuPrincipal()
        + saisirIdCapteur() : String
        + saisirParametres() : ParametresZone
        + saisirPosition() : ParametresPosition
        + choisirCapteurRef(idCapteur, debut, fin) : ParametresComparaison
        + choisirPurificateur() : String
        + choisirParticulierEtCapteur() : ParametresFiabilite
        + afficherResultat(resultat : Object)
        + afficherAlerte(message : String)
    }
}

' Relations métiers
Capteur "1" -- "*" Mesure : produit >
Mesure "*" -- "1" AttributMesure : concerne >
Particulier "1" -- "0..1" Capteur : possède >
Fournisseur "1" -- "*" Purificateur : gère >

' Relations Architecture
ConsoleUI ..> AirQualityService : utilise >
ConsoleUI ..> AdministrationService : utilise >
ConsoleUI ..> EnvironmentalService : utilise >

AirQualityService ..> DataReader : lit >
AirQualityService ..> AdministrationService : utilise >
AdministrationService ..> DataReader : lit/écrit >
EnvironmentalService ..> DataReader : lit >
EnvironmentalService ..> AirQualityService : utilise >

AirQualityService ..> PerformanceMonitor : utilise >
AdministrationService ..> PerformanceMonitor : utilise >
EnvironmentalService ..> PerformanceMonitor : utilise >
@enduml
