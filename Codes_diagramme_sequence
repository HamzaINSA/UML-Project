scenario 5 :
@startuml
title Observer l'impact d'un purificateur d'air
autonumber

actor Fournisseur
participant ConsoleUI
participant EnvironmentalService
participant DataReader
participant AirQualityService

Fournisseur -> ConsoleUI : choisirPurificateur(idPurificateur)
activate ConsoleUI

ConsoleUI -> EnvironmentalService : mesurerImpact(idPurificateur)
activate EnvironmentalService

EnvironmentalService -> DataReader : getPurificateur(idPurificateur)
activate DataReader
DataReader -->> EnvironmentalService : Purificateur(position, dateDebut, dateFin)
deactivate DataReader

note right of EnvironmentalService
  Le rayon d'action est estimé en
  cherchant le rayon maximal autour
  du purificateur où l'amélioration
  de la qualité de l'air reste
  mesurable (delta significatif).
end note

EnvironmentalService -> AirQualityService : calculerMoyenneZone(zone, periodeAvantDateDebut)
activate AirQualityService
AirQualityService -->> EnvironmentalService : indiceAvant
deactivate AirQualityService

EnvironmentalService -> AirQualityService : calculerMoyenneZone(zone, dateDebut, dateFin)
activate AirQualityService
AirQualityService -->> EnvironmentalService : indicePendant
deactivate AirQualityService

EnvironmentalService -> EnvironmentalService : calculerDelta(indiceAvant, indicePendant)
activate EnvironmentalService #DarkSalmon
deactivate EnvironmentalService

EnvironmentalService -> EnvironmentalService : estimerRayonAction()
activate EnvironmentalService #DarkSalmon
deactivate EnvironmentalService

EnvironmentalService -->> ConsoleUI : (deltaQualite, rayonAction)
deactivate EnvironmentalService

ConsoleUI -->> Fournisseur : afficher(deltaQualite, rayonAction)
deactivate ConsoleUI

@enduml
