scenario 1 : Analyser un capteur (determoiner s'il est fonctionel ou pas )
@startuml
title Analyser un capteur
autonumber

actor Agence
participant ConsoleUI
participant AdministrationService
participant DataReader

Agence -> ConsoleUI : saisirIdCapteur(idCapteur)
activate ConsoleUI

ConsoleUI -> AdministrationService : analyserCapteur(idCapteur)
activate AdministrationService

AdministrationService -> DataReader : getMesuresCapteur(idCapteur)
activate DataReader
DataReader -->> AdministrationService : List<Mesure>
deactivate DataReader

AdministrationService -> DataReader : getCapteursVoisins(idCapteur)
activate DataReader
DataReader -->> AdministrationService : List<Capteur>
deactivate DataReader

note right of AdministrationService
  Vérification de la cohérence :
  - comparaison avec les capteurs
    voisins géographiquement
  - détection de valeurs aberrantes
end note

loop pour chaque capteur voisin
    AdministrationService -> DataReader : getMesuresCapteur(idVoisin)
    activate DataReader
    DataReader -->> AdministrationService : List<Mesure>
    deactivate DataReader
end

alt Capteur fonctionnel
    AdministrationService -->> ConsoleUI : rapportAnalyse(OK)
    ConsoleUI -->> Agence : "Capteur fonctionnel"
else Capteur défaillant
    AdministrationService -->> ConsoleUI : rapportAnalyse(DEFAILLANT)
    ConsoleUI -->> Agence : Alerte : "Capteur défaillant"
end

deactivate AdministrationService
deactivate ConsoleUI
@enduml

scenario2 :
@startuml
title Calculer la qualité de l'air sur une zone
autonumber

actor Agence
participant ConsoleUI
participant AirQualityService
participant DataReader
participant AdministrationService

Agence -> ConsoleUI : getQualityAir(lat, lon, rayon, debut, fin)
activate ConsoleUI

ConsoleUI -> AirQualityService : calculerMoyenneAQI(lat, lon, rayon, debut, fin)
activate AirQualityService

AirQualityService -> DataReader : getCapteursValidesDansRayon(lat, lon, rayon)
activate DataReader
DataReader -->> AirQualityService : List<Capteur>
deactivate DataReader

note right of AirQualityService
  Les mesures issues des Particuliers
  marqués comme non fiables sont
  exclues du calcul.
end note

loop pour chaque Capteur retenu
    AirQualityService -> DataReader : getMesuresPeriode(idCapteur, debut, fin)
    activate DataReader
    DataReader -->> AirQualityService : List<Mesure> (filtrées)
    deactivate DataReader
end

AirQualityService -> AirQualityService : calculerIndiceATMOMoyen()
activate AirQualityService #DarkSalmon
deactivate AirQualityService

AirQualityService -> AdministrationService : attribuerPoints(particuliersImpliques)
activate AdministrationService
AdministrationService -->> AirQualityService : pointsAttribues
deactivate AdministrationService

AirQualityService -->> ConsoleUI : indiceATMOMoyen
deactivate AirQualityService

ConsoleUI -->> Agence : afficher(indiceATMOMoyen)
deactivate ConsoleUI
@enduml
