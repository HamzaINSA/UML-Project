scenario 4 :
@startuml
title Estimer la qualité de l'air à une position
autonumber

actor Agence
participant ConsoleUI
participant AirQualityService
participant DataReader
participant AdministrationService

Agence -> ConsoleUI : saisirPosition(lat, lon, timestamp)
activate ConsoleUI

ConsoleUI -> AirQualityService : estimerQualitePosition(lat, lon, timestamp)
activate AirQualityService

AirQualityService -> DataReader : getTousCapteurs()
activate DataReader
DataReader -->> AirQualityService : List<Capteur>
deactivate DataReader

alt Un capteur existe exactement à cette position
    AirQualityService -> DataReader : getMesures(idCapteur, timestamp)
    activate DataReader
    DataReader -->> AirQualityService : List<Mesure>
    deactivate DataReader

    AirQualityService -> AirQualityService : calculerIndiceATMO()
    activate AirQualityService #DarkSalmon
    deactivate AirQualityService

else Aucun capteur à cette position exacte

    note right of AirQualityService
      Interpolation spatiale :
      sélection des N capteurs les
      plus proches, puis moyenne
      pondérée par l'inverse de la
      distance (plus un capteur est
      proche, plus son poids est élevé).
    end note

    AirQualityService -> AirQualityService : selectionnerNCapteursProches()
    activate AirQualityService #DarkSalmon
    deactivate AirQualityService

    loop pour chaque capteur proche
        AirQualityService -> DataReader : getMesures(idCapteur, timestamp)
        activate DataReader
        DataReader -->> AirQualityService : List<Mesure>
        deactivate DataReader
    end

    AirQualityService -> AirQualityService : interpolerPondereeParDistance()
    activate AirQualityService #DarkSalmon
    deactivate AirQualityService
end

AirQualityService -> AdministrationService : attribuerPoints(particuliersImpliques)
activate AdministrationService
AdministrationService -->> AirQualityService : pointsAttribues
deactivate AdministrationService

AirQualityService -->> ConsoleUI : indiceATMOEstime
deactivate AirQualityService

ConsoleUI -->> Agence : afficher(indiceATMOEstime)
deactivate ConsoleUI

@enduml
