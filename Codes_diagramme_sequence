scenario 3 :

@startuml
title Comparer des capteurs par similarité
autonumber

actor Agence
participant ConsoleUI
participant AirQualityService
participant DataReader

Agence -> ConsoleUI : choisirCapteurRef(idRef, periode)
activate ConsoleUI

ConsoleUI -> AirQualityService : comparerCapteurs(idRef, periode)
activate AirQualityService

AirQualityService -> DataReader : getMesures(idRef, periode)
activate DataReader
DataReader -->> AirQualityService : List<Mesure> (référence)
deactivate DataReader

AirQualityService -> DataReader : getAutresCapteurs(idRef)
activate DataReader
DataReader -->> AirQualityService : List<Capteur>
deactivate DataReader

note right of AirQualityService
  Score de similarité = distance
  euclidienne entre les vecteurs
  de mesures moyennes par
  AttributMesure (O3, SO2, NO2, PM10).
  Plus le score est bas, plus le
  capteur est similaire à la référence.
end note

loop pour chaque autre Capteur
    AirQualityService -> DataReader : getMesures(idCapteur, periode)
    activate DataReader
    DataReader -->> AirQualityService : List<Mesure>
    deactivate DataReader

    AirQualityService -> AirQualityService : calculerScoreSimilarite()
    activate AirQualityService #DarkSalmon
    deactivate AirQualityService
end

AirQualityService -> AirQualityService : trierParScoreCroissant()
activate AirQualityService #DarkSalmon
deactivate AirQualityService

AirQualityService -->> ConsoleUI : classementTrie
deactivate AirQualityService

ConsoleUI -->> Agence : afficher(classementTrie)
deactivate ConsoleUI

@enduml

