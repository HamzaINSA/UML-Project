scenario 2:
ALGORITHME calculerMoyenneZone
ENTRÉES : latCentre, lonCentre, rayon, periode (debut, fin)
SORTIE  : indiceATMOMoyen

DÉBUT
    PerformanceMonitor.demarrer("calculerMoyenneZone")

    capteursZone ← DataReader.getCapteursDansRayon(latCentre, lonCentre, rayon)
    moyennesParAttribut ← table vide   // O3 → [], SO2 → [], NO2 → [], PM10 → []
    particuliersImpliques ← ensemble vide

    POUR CHAQUE c DANS capteursZone FAIRE
        // Exclusion des données issues d'utilisateurs non fiables
        SI c.proprietaire ≠ NULL ET c.proprietaire.estFiable = FAUX ALORS
            CONTINUER
        FIN SI

        mesures ← DataReader.getMesures(c.id, periode)
        mesures ← filtrer(mesures, m → m.estValide = VRAI)

        SI mesures est vide ALORS CONTINUER FIN SI

        POUR CHAQUE attribut DANS {O3, SO2, NO2, PM10} FAIRE
            moyAttr ← moyenne(mesures, attribut)
            SI moyAttr ≠ NULL ALORS
                moyennesParAttribut[attribut].ajouter(moyAttr)
            FIN SI
        FIN POUR

        SI c.proprietaire est un Particulier ALORS
            particuliersImpliques.ajouter(c.proprietaire)
        FIN SI
    FIN POUR

    // Calcul de l'indice ATMO à partir des sous-indices
    sousIndices ← table vide
    POUR CHAQUE attribut DANS {O3, SO2, NO2, PM10} FAIRE
        moyenneGlobale ← moyenne(moyennesParAttribut[attribut])
        sousIndices[attribut] ← convertirEnSousIndiceATMO(attribut, moyenneGlobale)
    FIN POUR
    indiceATMO ← MAX(sousIndices)   // ATMO = pire des sous-indices

    // Récompenses
    POUR CHAQUE p DANS particuliersImpliques FAIRE
        AdministrationService.attribuerPoint(p, 1)
    FIN POUR

    PerformanceMonitor.arreter("calculerMoyenneZone")
    RETOURNER indiceATMO
FIN
