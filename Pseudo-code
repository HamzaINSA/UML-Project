Scenario 4:
ALGORITHME estimerQualitePosition
ENTRÉES : lat, lon, timestamp
SORTIE  : indiceATMOEstime

DÉBUT
    PerformanceMonitor.demarrer("estimerQualitePosition")

    tousCapteurs ← DataReader.getTousCapteurs()
    capteurExact ← chercher(tousCapteurs, c → c.lat = lat ET c.lon = lon)
    particuliersImpliques ← ensemble vide

    SI capteurExact ≠ NULL ALORS
        mesures ← DataReader.getMesuresAuTimestamp(capteurExact.id, timestamp)
        indiceATMO ← calculerIndiceATMO(mesures)

        SI capteurExact.proprietaire est un Particulier
           ET capteurExact.proprietaire.estFiable ALORS
            particuliersImpliques.ajouter(capteurExact.proprietaire)
        FIN SI
    SINON
        // Interpolation spatiale pondérée par l'inverse de la distance
        // Plus un capteur est proche, plus son poids est élevé
        proches ← N_capteursLesPlusProches(tousCapteurs, lat, lon, N)

        sommePonderee ← table vide   // par attribut
        sommePoids    ← table vide

        POUR CHAQUE c DANS proches FAIRE
            SI c.proprietaire ≠ NULL ET c.proprietaire.estFiable = FAUX ALORS
                CONTINUER
            FIN SI

            mesures ← DataReader.getMesuresAuTimestamp(c.id, timestamp)
            SI mesures est vide ALORS CONTINUER FIN SI

            d ← distance(lat, lon, c.lat, c.lon)
            poids ← 1 / (d² + ε)        // ε évite la division par 0

            POUR CHAQUE attribut DANS {O3, SO2, NO2, PM10} FAIRE
                v ← valeur(mesures, attribut)
                SI v ≠ NULL ALORS
                    sommePonderee[attribut] ← sommePonderee[attribut] + v × poids
                    sommePoids[attribut]    ← sommePoids[attribut]    + poids
                FIN SI
            FIN POUR

            SI c.proprietaire est un Particulier ALORS
                particuliersImpliques.ajouter(c.proprietaire)
            FIN SI
        FIN POUR

        valeursInterpolees ← table vide
        POUR CHAQUE attribut DANS {O3, SO2, NO2, PM10} FAIRE
            valeursInterpolees[attribut] ← sommePonderee[attribut] / sommePoids[attribut]
        FIN POUR

        indiceATMO ← calculerIndiceATMO(valeursInterpolees)
    FIN SI

    POUR CHAQUE p DANS particuliersImpliques FAIRE
        AdministrationService.attribuerPoint(p, 1)
    FIN POUR

    PerformanceMonitor.arreter("estimerQualitePosition")
    RETOURNER indiceATMO
FIN
