scenario 6:
ALGORITHME classifierFiabilite
ENTRÉES : idCapteur (capteur d'un Particulier)
SORTIE  : statut ∈ {FIABLE, NON_FIABLE}

DÉBUT
    PerformanceMonitor.demarrer("classifierFiabilite")

    capteur     ← DataReader.getCapteur(idCapteur)
    particulier ← capteur.proprietaire
    longuePeriode ← (maintenant() − DUREE_ANALYSE, maintenant())

    mesuresPrive   ← DataReader.getMesuresCapteur(idCapteur, longuePeriode)
    capteursVoisinsOff ← DataReader.getCapteursOfficielsVoisins(
                            capteur, RAYON_VOISINAGE)

    nbAnomalies ← 0
    nbAttributs ← 0

    POUR CHAQUE attribut DANS {O3, SO2, NO2, PM10} FAIRE
        moyennePrive ← moyenne(mesuresPrive, attribut)

        valeursVoisins ← liste vide
        POUR CHAQUE v DANS capteursVoisinsOff FAIRE
            mv ← DataReader.getMesuresCapteur(v.id, longuePeriode)
            ajouter moyenne(mv, attribut) à valeursVoisins
        FIN POUR
        moyenneVoisinage ← moyenne(valeursVoisins)
        ecartType        ← ecartType(valeursVoisins)

        // Critères d'anomalie :
        //  1. écart trop important par rapport aux capteurs voisins
        //  2. valeurs constantes suspectes (variance ≈ 0)
        //  3. valeurs hors bornes physiques de l'attribut
        SI |moyennePrive − moyenneVoisinage| > K × ecartType ALORS
            nbAnomalies ← nbAnomalies + 1
        SI varianceConstante(mesuresPrive, attribut) ALORS
            nbAnomalies ← nbAnomalies + 1
        SI moyennePrive HORS bornesPhysiques(attribut) ALORS
            nbAnomalies ← nbAnomalies + 1

        nbAttributs ← nbAttributs + 1
    FIN POUR

    SI nbAnomalies ≤ SEUIL_TOLERANCE ALORS
        statut ← FIABLE
        capteur.estFiable    ← VRAI
        particulier.estFiable ← VRAI
        DataReader.sauvegarderCapteur(capteur)
    SINON
        statut ← NON_FIABLE
        capteur.estFiable    ← FAUX
        particulier.estFiable ← FAUX
        DataReader.sauvegarderCapteur(capteur)
        DataReader.marquerMesuresInvalides(idCapteur)
        AdministrationService.desactiverAttributionPoints(particulier)
    FIN SI

    PerformanceMonitor.arreter("classifierFiabilite")
    RETOURNER statut
FIN
