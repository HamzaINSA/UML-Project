scenario 5:
ALGORITHME mesurerImpact
ENTRÉES : idPurificateur
SORTIE  : { deltaQualite, rayonAction }

DÉBUT
    PerformanceMonitor.demarrer("mesurerImpact")

    purif ← DataReader.getPurificateur(idPurificateur)
    SI purif = NULL ALORS RETOURNER ÉCHEC FIN SI

    duree         ← purif.dateFin − purif.dateDebut
    periodeAvant  ← (purif.dateDebut − duree, purif.dateDebut)
    periodePendant ← (purif.dateDebut, purif.dateFin)

    // Recherche du rayon d'action : on teste plusieurs rayons croissants
    // et on conserve le plus grand où l'amélioration reste mesurable.
    rayonAction ← 0
    deltaRetenu ← 0

    POUR r DE RAYON_MIN À RAYON_MAX PAR PAS pas FAIRE
        indiceAvant   ← AirQualityService.calculerMoyenneZone(
                            purif.lat, purif.lon, r, periodeAvant)
        indicePendant ← AirQualityService.calculerMoyenneZone(
                            purif.lat, purif.lon, r, periodePendant)

        delta ← indiceAvant − indicePendant   // ATMO : plus bas = mieux

        SI delta ≥ SEUIL_AMELIORATION_SIGNIFICATIVE ALORS
            rayonAction ← r
            deltaRetenu ← delta
        SINON
            // L'amélioration n'est plus mesurable au-delà : on s'arrête
            SORTIR DE LA BOUCLE
        FIN SI
    FIN POUR

    PerformanceMonitor.arreter("mesurerImpact")
    RETOURNER (deltaQualite = deltaRetenu, rayonAction)
FIN
